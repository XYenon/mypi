{
  "name": "mypi",
  "version": "0.0.1",
  "keywords": [
    "pi-package"
  ],
  "author": "XYenon <i@xyenon.bid>",
  "license": "AGPL-3.0",
  "type": "module",
  "pi": {
    "extensions": [
      "./extensions",
      "-./extensions/utils.ts",
      "node_modules/mitsupi/extensions/context.ts",
      "node_modules/mitsupi/extensions/notify.ts",
      "node_modules/mitsupi/extensions/review.ts",
      "node_modules/pi-hashline-edit/index.ts",
      "node_modules/pi-mcp-adapter/index.ts",
      "node_modules/pi-powerline-footer/index.ts",
      "node_modules/pi-rewind-hook/index.ts",
      "node_modules/pi-skill-palette/index.ts",
      "node_modules/pi-subagents/index.ts",
      "node_modules/pi-web-access/index.ts"
    ],
    "skills": [
      "./skills",
      "node_modules/pi-subagents/skills",
      "node_modules/pi-web-access/skills"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./themes",
      "node_modules/pi-catppuccin/themes"
    ]
  },
  "bundledDependencies": [
    "mitsupi",
    "pi-catppuccin",
    "pi-hashline-edit",
    "pi-mcp-adapter",
    "pi-powerline-footer",
    "pi-rewind-hook",
    "pi-skill-palette",
    "pi-subagents",
    "pi-web-access"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "preview:renderers": "tsx scripts/preview-renderers.ts"
  },
  "dependencies": {
    "mitsupi": "^1.6.0",
    "pi-catppuccin": "github:XYenon/catppuccin-pi-coding-agent",
    "pi-hashline-edit": "^0.6.1",
    "pi-mcp-adapter": "^2.8.0",
    "pi-powerline-footer": "^0.5.6",
    "pi-rewind-hook": "^1.8.4",
    "pi-skill-palette": "^1.1.0",
    "pi-subagents": "^0.27.0",
    "pi-web-access": "^0.10.7",
    "toml": "^4.1.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  }
}
