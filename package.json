{
  "name": "mypi",
  "version": "0.0.1",
  "keywords": [
    "pi-package"
  ],
  "author": "XYenon <i@xyenon.bid>",
  "license": "AGPL-3.0",
  "type": "module",
  "pi": {
    "extensions": [
      "./extensions",
      "-./extensions/utils.ts",
      "node_modules/pi-mcp-adapter/index.ts",
      "node_modules/pi-powerline-footer/index.ts",
      "node_modules/pi-rewind-hook/index.ts",
      "node_modules/pi-skill-palette/index.ts",
      "node_modules/pi-subagents/index.ts"
    ],
    "skills": [
      "./skills",
      "node_modules/pi-subagents/skills"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./themes"
    ]
  },
  "bundledDependencies": [
    "pi-mcp-adapter",
    "pi-powerline-footer",
    "pi-rewind-hook",
    "pi-skill-palette",
    "pi-subagents"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@types/jsdom": "^27.0.0",
    "@types/turndown": "^5.0.6",
    "jsdom": "^28.0.0",
    "pi-mcp-adapter": "^2.4.2",
    "pi-powerline-footer": "^0.4.17",
    "pi-rewind-hook": "^1.8.3",
    "pi-skill-palette": "^1.1.0",
    "pi-subagents": "^0.18.0",
    "toml": "^3.0.0",
    "turndown": "^7.2.2"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0"
  }
}
